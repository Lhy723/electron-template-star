{
  "name": "electron-template-star",
  "version": "1.0.0",
  "description": "A modern Electron application template with Vue 3, Vite, TypeScript, Element Plus, Pinia, Vue Router, ShadcnUI and Tailwind CSS",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:web": "vue-tsc --noEmit && vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:web && electron-builder",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit"
  },
  "keywords": [
    "electron",
    "vue3",
    "vite",
    "typescript",
    "element-plus",
    "pinia",
    "vue-router",
    "shadcn-ui",
    "tailwindcss",
    "template"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.8.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.2",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^1.8.25",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@radix-ui/react-slot": "^1.0.2",
    "@vueuse/core": "^10.6.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "element-plus": "^2.4.4",
    "lucide-vue-next": "^0.294.0",
    "pinia": "^2.1.7",
    "radix-vue": "^1.2.6",
    "tailwind-merge": "^2.1.0",
    "tailwindcss-animate": "^1.0.7",
    "vue": "^3.3.8",
    "vue-router": "^4.2.5"
  },
  "build": {
    "appId": "com.electron.template.star",
    "productName": "Electron Template Star",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron",
      "dist"
    ],
    "mac": {
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}